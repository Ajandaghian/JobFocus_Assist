{
  "manifest_version": 3,
  "name": "JobFocus Assist: Cleaner LinkedIn Job Search",
  "version": "1.0.0",
  "description": "JobFocus Assist mutes viewed jobs, marks applied jobs, and highlights user-defined keywords inside LinkedIn job descriptions.",
  "homepage_url": "https://github.com/Ajandaghian/JobFocus_Assist",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "JobFocus Assist",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/brand/jobfocus-assist-icon-16.png",
      "32": "assets/brand/jobfocus-assist-icon-32.png",
      "48": "assets/brand/jobfocus-assist-icon-48.png",
      "128": "assets/brand/jobfocus-assist-icon-128.png"
    }
  },
  "icons": {
    "16": "assets/brand/jobfocus-assist-icon-16.png",
    "32": "assets/brand/jobfocus-assist-icon-32.png",
    "48": "assets/brand/jobfocus-assist-icon-48.png",
    "128": "assets/brand/jobfocus-assist-icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://linkedin.com/jobs/*",
        "https://*.linkedin.com/jobs/*",
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
